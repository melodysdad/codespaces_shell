{
  "name": "codespaces-shell",
  "containerEnv": {
    "GITHUB_TOKEN": "${localEnv:NPM_PAT}"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "nodeGypDependencies": true,
      "version": "lts"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "GitHub.vscode-github-actions"
      ]
    }
  }
}
